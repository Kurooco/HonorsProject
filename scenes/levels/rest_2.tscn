[sub_resource type="GDScript" id="GDScript_c1ga2"]
resource_name = "pipe_machine"
script/source = "extends \"res://scenes/components/interaction_area.gd\"

@onready var mini_game: Node2D = $SubViewportContainer/SubViewport/MiniGame
@onready var pipe_block: StaticBody2D = $\"../PipeBlock\"
@onready var pipe_bird_free: Area2D = $\"../DialogueAreas/PipeBirdFree\"
@onready var pipe_bird: Area2D = $\"../DialogueAreas/PipeBird\"
@onready var back_button_layer: CanvasLayer = $BackButtonLayer


func _on_activated():
	var camera = get_tree().get_first_node_in_group(\"level_camera\")
	camera.focus(position, Vector2(5, 5))
	Autoload.set_player_disabled(true)
	await get_tree().create_timer(1.0).timeout
	mini_game.enabled = true
	back_button_layer.show()


func _on_mini_game_won() -> void:
	$CollisionShape2D.set_deferred(\"disabled\", true)
	$AnimatedSprite2D.frame = 1
	if(is_instance_valid(pipe_block)):
		pipe_block.queue_free()
		pipe_bird_free.disabled = false


func _on_mini_game_exit() -> void:
	var camera = get_tree().get_first_node_in_group(\"level_camera\")
	camera.focus_on_player(Vector2(1, 1))
	Autoload.set_player_disabled(false)
	replace_game()
	back_button_layer.hide()


func _on_mini_game_restarted() -> void:
	var new_game = replace_game()
	new_game.enable()


func replace_game():
	var new_game = load(mini_game.scene_file_path).instantiate()
	new_game.scene_file_path = mini_game.scene_file_path
	new_game.enabled = false
	new_game.transform = mini_game.transform
	new_game.won.connect(_on_mini_game_won)
	new_game.exit.connect(_on_mini_game_exit)
	new_game.restarted.connect(_on_mini_game_restarted)
	mini_game.get_parent().add_child(new_game)
	var old_game = mini_game
	mini_game = new_game
	mini_game.get_parent().remove_child(old_game)
	old_game.queue_free()
	return new_game


func _on_dialogic_signal_handler_matched() -> void:
	$\"../DialogueAreas/PipeBird\".position = Vector2(-174, 27)
"

